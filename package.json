{
  "name": "hisabkitab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "pnpm -r --workspace-concurrency=1 test",
    "typecheck": "pnpm -r typecheck",
    "verify": "pnpm --filter @hisab/shared verify",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "concurrently -n landing,ledger,payments,webhook -c magenta,cyan,yellow,green \"pnpm dev:landing\" \"pnpm dev:ledger\" \"pnpm dev:payments\" \"pnpm dev:webhook\"",
    "dev:backend": "concurrently -n ledger,payments,webhook -c cyan,yellow,green \"pnpm dev:ledger\" \"pnpm dev:payments\" \"pnpm dev:webhook\"",
    "dev:landing": "cd landing && pnpm dev",
    "dev:ledger": "pnpm --filter @hisab/mcp-ledger start",
    "dev:payments": "pnpm --filter @hisab/mcp-payments start",
    "dev:webhook": "pnpm --filter @hisab/orchestrator start",
    "khalti:stub": "pnpm --filter @hisab/mcp-payments khalti:stub",
    "db:studio": "pnpm --filter @hisab/db studio",
    "up": "docker compose -f compose.yaml -f compose.dev.yaml up --build",
    "up:detached": "docker compose -f compose.yaml -f compose.dev.yaml up -d --build",
    "down": "docker compose -f compose.yaml -f compose.dev.yaml down"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "eslint": "^9.39.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  },
  "pnpm": {
    "overrides": {
      "shell-quote": "^1.8.4"
    }
  }
}
