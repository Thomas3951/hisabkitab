# Tax configuration (FY 2082/83 — verified rates from PRD v1.1 §5).
# All rates are basis points (1300 = 13%). All money is integer paisa (1 NPR = 100 paisa).
# These are CONFIG, not code — a rate change is a one-line update here.
VAT_RATE_BPS=1300
TDS_SERVICE_VAT_REGISTERED_BPS=150
TDS_SERVICE_PAN_ONLY_BPS=1500
TDS_RENT_ENTITY_BPS=1000
TDS_VEHICLE_VAT_REGISTERED_BPS=150
TDS_VEHICLE_NON_VAT_BPS=1000
TDS_DIVIDEND_BPS=500
TDS_INTEREST_BPS=1500
TDS_COMMISSION_BPS=1500
# Contract TDS applies once cumulative payments to one party exceed this per year (NPR 50,000).
CONTRACT_TDS_THRESHOLD_PAISA=5000000
# Input VAT credit claimable within this many years of the invoice date (VAT Act Sec 18).
INPUT_CREDIT_WINDOW_YEARS=1
# VAT math check tolerance (paisa) for "vat ≈ 13% of taxable".
VAT_TOLERANCE_PAISA=1
# Sanity ceiling for a single entry (10^11 paisa = NPR 1 billion).
MAX_AMOUNT_PAISA=100000000000

# ---------------------------------------------------------------- Phase 1: DB + Ledger MCP
# App runtime connects as the RLS-constrained role; admin URL is for migrations only.
DATABASE_URL=postgres://hisab_app:CHANGE_ME@localhost:5432/hisabkitab
ADMIN_DATABASE_URL=postgres://postgres:CHANGE_ME@localhost:5432/hisabkitab
# Ledger MCP auth: service bearer token + HMAC secret for signed tenant session metadata.
LEDGER_MCP_TOKEN=
TENANT_SIGNING_SECRET=
# Field-level PII encryption (P15 §9): AES-256-GCM master key for PAN/VAT numbers,
# 32 bytes base64 (generate: `openssl rand -base64 32`). UNSET in dev/test ⇒ values
# are stored as plaintext (documented dev mode). MUST be set + rotated in production.
FIELD_ENCRYPTION_KEY=
PORT=8801

# ---------------------------------------------------------------- Phase 2: Managed Agents
ANTHROPIC_API_KEY=
# Deployed https URL of the Ledger MCP (placeholder until publicly deployed).
LEDGER_MCP_URL=https://ledger.hisabkitab.example/mcp
# Created by `agent:setup` (also saved to packages/orchestrator/agent-ids.local.json).
AGENT_ID=
ENVIRONMENT_ID=
# Agent model. Money-grade reasoning = Opus (production default). Iterate on cheap
# Sonnet to keep dev cost low, then re-run `agent:setup --update` with Opus for the pilot.
#   dev:  HISAB_MODEL=claude-sonnet-4-6
#   prod: HISAB_MODEL=claude-opus-4-8  (default if unset)
HISAB_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------- Phase 3: WhatsApp Cloud API
# Orchestrator webhook connects as hisab_orch (cross-tenant role, migration 0002).
# (Set DATABASE_URL to this value for `pnpm --filter @hisab/orchestrator start`.)
# postgres://hisab_orch:CHANGE_ME@localhost:5432/hisabkitab
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ACCOUNT_ID=
WA_ACCESS_TOKEN=
# Any random string; must match what you enter in the Meta webhook config UI.
WA_WEBHOOK_VERIFY_TOKEN=
# Meta App Secret — verifies X-Hub-Signature-256 on every webhook POST.
WA_APP_SECRET=

# ---------------------------------------------------------------- Phase 5: Payments MCP (Khalti)
# Khalti merchant secret (sandbox: from test-admin.khalti.com; prod: issued after MOU).
KHALTI_SECRET_KEY=
# Sandbox: https://dev.khalti.com  |  production: https://khalti.com  (unset = sandbox).
KHALTI_ORIGIN=https://dev.khalti.com
# Service bearer for the payments MCP (like LEDGER_MCP_TOKEN).
PAYMENTS_MCP_TOKEN=
# Deployed https URL of the Payments MCP (omit to build the agent WITHOUT payments).
PAYMENTS_MCP_URL=https://pay.hisabkitab.example/mcp
# Public base for the Khalti return URL; the payer's browser is redirected here.
PAYMENTS_PUBLIC_BASE_URL=http://localhost:8802
WEBSITE_URL=https://hisabkitab.example
# Cross-tenant handle for the unauthenticated return-URL callback (hisab_orch).
CALLBACK_DATABASE_URL=postgres://hisab_orch:CHANGE_ME@localhost:5432/hisabkitab

# ---------------------------------------------------------------- Phase 6: Reminder scheduler
# BullMQ needs Redis. Local dev: redis://127.0.0.1:6379.
REDIS_URL=redis://127.0.0.1:6379
# Run the monthly reminder worker in this process (set 0 on webhook-only nodes).
SCHEDULER_ENABLED=1
# BS day-of-month to prepare + nudge the return (statutory deadline is the 25th).
REMINDER_BS_DAY=20

# ---------------------------------------------------------------- P16: Docker Compose
# Used by compose.yaml. Dev defaults are baked into compose.dev.yaml, so for local
# `pnpm up` you do NOT need to set these. For PROD (compose.prod.yaml) set real values.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hisabkitab
# Passwords for the two RLS app roles (must match infra/postgres/init in prod).
HISAB_APP_PASSWORD=hisab_app_dev
HISAB_ORCH_PASSWORD=hisab_orch_dev
# GHCR image coordinates for compose.prod.yaml (CD sets IMAGE_TAG=sha-<commit>).
GHCR_OWNER=nikegunn
IMAGE_TAG=latest

# Never commit real keys; this file holds only names and safe defaults.
